{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText8",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText9",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "split1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          InvoiceNo as string,",
				"          StockCode as string,",
				"          Description as string,",
				"          Quantity as short,",
				"          InvoiceDate as timestamp,",
				"          UnitPrice as double,",
				"          CustomerID as double,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          InvoiceNo,",
				"          StockCode,",
				"          Description,",
				"          UnitPrice,",
				"          CustomerID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(CustomerID!=17870.0) ~> filter1",
				"filter1 split(Description==\"WOODEN FRAME ANTIQUE WHITE\",",
				"     disjoint: false) ~> split1@(WOODENFRAMEANTIQUEWHITE, OtherThanWOODENFRAMEANTIQUEWHITE)",
				"split1@WOODENFRAMEANTIQUEWHITE aggregate(CustomerID = max(CustomerID)) ~> aggregate1",
				"split1@OtherThanWOODENFRAMEANTIQUEWHITE sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}